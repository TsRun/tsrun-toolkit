{
  "name": "tsrun-housekeeping",
  "description": "Claude Code housekeeping: /tsrun-housekeeping:clean-sessions skill, plus Stop hooks that play a sound and prune autocommit-generated session transcripts.",
  "version": "1.0.0",
  "author": { "name": "Mathis Serrier" },
  "skills": "./skills/",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/sound.sh\"",
            "shell": "bash",
            "async": true,
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/cleanup-sessions.sh\"",
            "shell": "bash",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
