{
  "name": "tsrun-toolkit",
  "description": "Dev workflow skills (fix-types, doc, clone-website) with Obsidian MCP integration.",
  "version": "2.2.0",
  "author": { "name": "Mathis Serrier" },
  "skills": "./skills/",
  "userConfig": {
    "obsidian_port": {
      "title": "Obsidian Port",
      "description": "Obsidian REST API port (default: 27124)",
      "type": "string",
      "sensitive": false
    },
    "obsidian_api_key": {
      "title": "Obsidian API Key",
      "description": "Obsidian Local REST API key (from plugin settings)",
      "type": "string",
      "sensitive": false
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/sound.sh\"",
            "shell": "bash",
            "async": true,
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/autocommit.sh\"",
            "shell": "bash",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "${user_config.obsidian_api_key}",
        "OBSIDIAN_PORT": "${user_config.obsidian_port}"
      }
    }
  }
}
