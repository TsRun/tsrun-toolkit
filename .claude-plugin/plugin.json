{
  "name": "tsrun-toolkit",
  "description": "Dev workflow skills (commit, fix-types, doc, clone-website) with Obsidian MCP integration.",
  "version": "1.7.0",
  "author": { "name": "Mathis Serrier" },
  "skills": "./skills/",
  "userConfig": {
    "obsidian_port": {
      "title": "Obsidian Port",
      "description": "Obsidian REST API port (default: 27124)",
      "type": "string",
      "sensitive": false
    },
    "obsidian_api_key": {
      "title": "Obsidian API Key",
      "description": "Obsidian Local REST API key (from plugin settings)",
      "type": "string",
      "sensitive": false
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -c \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\chimes.wav').PlaySync()\"",
            "shell": "bash",
            "async": true,
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && git rev-parse --git-dir >/dev/null 2>&1 && [ -n \"$(git status --porcelain)\" ] && git add -A && git commit -m \"[UPDATE] auto-commit from Claude Code\" && git push || true",
            "shell": "bash",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "${user_config.obsidian_api_key}",
        "OBSIDIAN_PORT": "${user_config.obsidian_port}"
      }
    }
  }
}
